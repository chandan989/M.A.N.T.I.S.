# =============================================
# M.A.N.T.I.S. — Environment Configuration
# Market Analysis & Network Tactical Integration System
# =============================================
# Copy this file to .env and fill in your values.
# IMPORTANT: chmod 600 .env after filling in.
# NEVER commit .env to version control.

# -----------------------------------------------
# HEDERA NETWORK
# -----------------------------------------------
HEDERA_ACCOUNT_ID=0.0.XXXXXX
HEDERA_PRIVATE_KEY=302e...            # DER-encoded ED25519 private key
HEDERA_NETWORK=testnet                # testnet | mainnet

# -----------------------------------------------
# BONZO FINANCE VAULTS
# -----------------------------------------------
# Comma-separated list of Bonzo Vault contract IDs to manage
BONZO_VAULT_IDS=0.0.XXXXXXX
# See: https://docs.bonzo.finance/hub/bonzo-vaults-beta/bonzo-vaults-quickstart

# -----------------------------------------------
# LLM REASONING ENGINE (choose one)
# -----------------------------------------------
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=...
LLM_MODEL=gpt-4o                     # gpt-4o | claude-3-5-sonnet | deepseek-chat

# -----------------------------------------------
# ORACLE SKILL — Price & Volatility Feeds
# -----------------------------------------------
SUPRA_ORACLE_ENDPOINT=https://api.supraoracles.com/rpc/
SUPRA_ORACLE_API_KEY=...
ORACLES_HBAR_PAIR=HBAR_USDC

# -----------------------------------------------
# SENTRY SKILL — Sentiment & News Monitoring
# -----------------------------------------------
TWITTER_BEARER_TOKEN=...
CRYPTOPANIC_API_KEY=...               # Get at: https://cryptopanic.com/developers/api/
SENTRY_KEYWORDS=HBAR,Hedera,Bonzo,SaucerSwap
SENTRY_LOOKBACK_MINUTES=30

# -----------------------------------------------
# COMMS SKILL — User Notifications
# -----------------------------------------------
COMMS_CHANNEL=telegram                # telegram | whatsapp
TELEGRAM_BOT_TOKEN=...               # From @BotFather
TELEGRAM_CHAT_ID=...                 # Your personal Telegram Chat ID

# -----------------------------------------------
# AGENT BEHAVIOR
# -----------------------------------------------
RISK_PROFILE=moderate                 # conservative | moderate | aggressive
VOLATILITY_THRESHOLD_WIDEN=0.60      # Vol above this → widen range
VOLATILITY_THRESHOLD_TIGHTEN=0.35    # Vol below this → tighten range
VOLATILITY_THRESHOLD_EMERGENCY=0.90  # Vol above this → consider full withdrawal
SENTIMENT_THRESHOLD_HARVEST=-0.40    # Sentiment below this → early harvest
SENTIMENT_THRESHOLD_SWAP=-0.70       # Sentiment below this → harvest + swap to stable
MIN_HARVEST_INTERVAL_HOURS=2         # Minimum hours between harvests
SENTRY_INTERVAL_SECONDS=60           # How often the agent loop runs

# -----------------------------------------------
# MEMORY / STATE
# -----------------------------------------------
MEMORY_BACKEND=sqlite                 # json | sqlite
MEMORY_DB_PATH=./data/mantis.db

# -----------------------------------------------
# LOGGING
# -----------------------------------------------
LOG_LEVEL=info                        # debug | info | warn | error
LOG_DIR=./logs
